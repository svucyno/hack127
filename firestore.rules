rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    // Users: anyone authenticated can read/write their own doc, Admin can read all
    match /users/{userId} {
      allow read, write: if isAuth();
    }

    // Products: read all auth, write all auth (role check done client-side)
    match /products/{doc} {
      allow read, write: if isAuth();
    }

    // Sales: all authenticated users
    match /sales/{doc} {
      allow read, write: if isAuth();
    }

    // Offers: all authenticated users
    match /offers/{doc} {
      allow read, write: if isAuth();
    }

    // Alerts: all authenticated users
    match /alerts/{doc} {
      allow read, write: if isAuth();
    }

    // Suppliers: all authenticated users
    match /suppliers/{doc} {
      allow read, write: if isAuth();
    }

    // Customers: all authenticated users
    match /customers/{doc} {
      allow read, write: if isAuth();
    }
  }
}
